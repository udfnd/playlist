# YouTube Data API v3 (for fetching public playlists without OAuth)
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Google OAuth Client (same project as YouTube API)
# Authorized redirect URIs must include:
#   http://localhost:3000/api/auth/callback/google   (dev)
#   https://YOUR_VERCEL_DOMAIN/api/auth/callback/google   (production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth v5 (Auth.js)
# Generate via: openssl rand -base64 32
AUTH_SECRET=

# Optional on Vercel (auto-detected via VERCEL_URL + trustHost).
# Set only if you need to override origin detection in self-hosted envs.
# NEXTAUTH_URL=https://your-domain.com

# Supabase (data platform)
# Project URL and publishable key are safe for the browser.
# Service role key bypasses RLS — keep server-side only, never ship to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
